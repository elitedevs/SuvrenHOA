# ─── Deployer ─────────────────────────────────────────────────────────────────
# Private key of the deployer EOA (needs ETH for gas on target network)
# NEVER commit a real private key. Use a hardware wallet or secrets manager in CI.
DEPLOYER_PRIVATE_KEY=0x...

# ─── Community Configuration ──────────────────────────────────────────────────
# Safe multisig address — receives all admin/board roles after deployment
# Recommend 3-of-5 Gnosis Safe on Base
BOARD_MULTISIG=0x...

# Number of lots / property NFT cap (e.g., 150)
MAX_LOTS=150

# NFT collection metadata
COMMUNITY_NAME=Faircroft Property
COMMUNITY_SYMBOL=FAIR

# ─── RPC / API Keys ───────────────────────────────────────────────────────────
# Used by foundry.toml [rpc_endpoints]
ALCHEMY_API_KEY=your_alchemy_api_key

# ─── Contract Verification ────────────────────────────────────────────────────
# Used by foundry.toml [etherscan] — works for both Base mainnet and Sepolia
BASESCAN_API_KEY=your_basescan_api_key

# ─── Testnet-only overrides ───────────────────────────────────────────────────
# Base Sepolia USDC: 0x036CbD53842c5426634e7929541eC2318f3dCF7e
# Base Mainnet USDC: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913 (hard-coded in DeployMainnet.s.sol)
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
